# System Configuration
DATABASE_URL=postgresql://mediunit:mediunit_pass@postgres:5432/mediunit_db
REDIS_URL=redis://redis:6379/0
JWT_SECRET=your_super_secret_jwt_key_here
FRONTEND_URL=http://localhost:3000

# PostgreSQL Defaults
POSTGRES_USER=mediunit
POSTGRES_PASSWORD=mediunit_pass
POSTGRES_DB=mediunit_db

# Logistics (Morocco)
OPERATIONS_CITY="Casablanca"
DELIVERY_RADIUS_KM="50"

# Cloudflare R2 Storage
R2_ENDPOINT_URL=https://your-r2-endpoint-url.storage.cloudflare.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=mediunit-storage
R2_PUBLIC_URL=https://pub-your-id.r2.dev

# Administration (Portugal)
# LEGAL_ENTITY_NAME="Ultimed Unipessoal Lda"
OFFICIAL_CORRESPONDENCE_ADDRESS="Av. da Liberdade, 123, 1250-143 Lisboa, Portugal"
LEGAL_ENTITY_COUNTRY="Portugal"
